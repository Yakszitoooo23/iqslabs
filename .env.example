# Copy this file to .env.local and fill in your values.
# Next.js does NOT load .env.example — only .env.local is used at runtime.

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...                    # $24.99/month recurring
STRIPE_SETUP_FEE_PRICE_ID=price_...          # $0.99 one-time setup fee

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opt-in test mode only — set to true to skip Stripe paywall locally
# NEXT_PUBLIC_SKIP_PAYWALL=true

# OpenAI
OPENAI_API_KEY=sk-...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_RESULTS=results@yourdomain.com
RESEND_FROM_LOGIN=login@yourdomain.com
